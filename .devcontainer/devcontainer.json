{
  "name": "Claude Guest Proxy",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "postStartCommand": "python -m src.guest_proxy.server",
  "forwardPorts": [8081],
  "remoteEnv": {
    "HOST_BRIDGE_URL": "${localEnv:HOST_BRIDGE_URL:http://host.docker.internal:8080}",
    "CONTAINER_NAME": "${localEnv:CONTAINER_NAME:}",
    "GUEST_PROXY_PORT": "${localEnv:GUEST_PROXY_PORT:8081}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}