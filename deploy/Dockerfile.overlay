# Dockerfile Overlay - Guest Proxy 集成片段
# 将以下内容添加到现有 Dockerfile

# ============================================
# 方式一：pip 安装（推荐）
# ============================================

# 添加依赖
RUN pip install aiohttp>=3.8.0 claude-agent-sdk>=0.1.0

# 设置环境变量
ENV HOST_BRIDGE_URL=http://host.docker.internal:8080
ENV GUEST_PROXY_PORT=8081

# ============================================
# 方式二：复制模块
# ============================================

# 复制模块文件
COPY src/guest_proxy /app/src/guest_proxy
COPY src/protocol /app/src/protocol
COPY src/host_bridge/client.py /app/src/host_bridge/client.py

# 创建 __init__.py 文件
RUN mkdir -p /app/src/host_bridge && \
    touch /app/src/__init__.py && \
    touch /app/src/host_bridge/__init__.py

# ============================================
# 启动配置
# ============================================

# 方式 A：使用入口脚本（推荐）
RUN cat > /entrypoint-guest-proxy.sh << 'EOF'
#!/bin/bash
# 启动 Guest Proxy（后台运行）
if [ "$ENABLE_GUEST_PROXY" = "true" ]; then
    python -m src.guest_proxy.server &
fi
# 执行原始命令
exec "$@"
EOF
RUN chmod +x /entrypoint-guest-proxy.sh

ENTRYPOINT ["/entrypoint-guest-proxy.sh"]

# 方式 B：使用 Supervisor 管理
# RUN pip install supervisor
# COPY supervisord.conf /etc/supervisor/conf.d/guest-proxy.conf

# ============================================
# 健康检查
# ============================================

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8081/health || exit 1

